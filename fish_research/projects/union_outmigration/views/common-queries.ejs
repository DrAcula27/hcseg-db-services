<!DOCTYPE html>
<html lang="en">
	<head>
		<%- include("./partials/head", { title: "HCSEG - Union Outmigration - Common Queries" }) %>
		<link rel="stylesheet" href="/css/form.css" />
    <link rel="stylesheet" href="/css/common-queries.css" />
	</head>
	<body>
		<%- include("./partials/header", { user: user, pageTitle: "Union River Summer Chum - Outmigration Program - Common Queries" }) %>

		<main class="container">
      <div class="btn-container">
        <a href="/projects/union_outmigration" class="btn btn-nav">Return to Union Outmigration Form</a>
        <a href="/projects" class="btn btn-nav">Return to Projects</a>
      </div>
			<section class="query-controls">
			<form method="get" action="/projects/union_outmigration/common-queries">
          <h2>Enter a Date Range:</h2>
          <div>
            <div>
              <label for="startDate">Start date:</label>
              <input type="date" id="startDate" name="startDate" value="<%= query.startDate || '' %>" />
            </div>
            <div>
              <label for="endDate">End date:</label>
              <input type="date" id="endDate" name="endDate" value="<%= query.endDate || '' %>" />
            </div>
            <button type="submit" class="btn">Run</button>
          </div>
				</form>
			</section>

			<section class="results">
				<h2>Query Results for: <em><%= query.startDate %> to <%= query.endDate %></em></h2>

        <h3>Chum Numbers:</h3>
				<ul>
					<li><strong>Chum caught:</strong> <%= totals.totalChum || 0 %></li>
					<li><strong>Chum morts:</strong> <%= totals.totalChumMorts || 0 %></li>
					<li><strong>Chum marked:</strong> <%= totals.totalChumMarked || 0 %></li>
					<li><strong>Chum marked morts:</strong> <%= totals.totalChumMarkedMort || 0 %></li>
					<li><strong>Chum recaptured:</strong> <%= totals.totalChumRecap || 0 %></li>
					<li><strong>Chum recapture morts:</strong> <%= totals.totalChumRecapMort || 0 %></li>
					<li><strong>Chum DNA samples taken:</strong> <%= totals.totalChumDnaTaken || 0 %></li>
					<li><strong>Chum trap efficiency:</strong>
						<%= totals.chumTrapEfficiency !== null ? totals.chumTrapEfficiency + '%' : 'N/A (no marked fish released)' %>
					</li>
				</ul>

        <h3>Chum DNA Samples</h3>
				<% if (dnaRecords && dnaRecords.length) { %>
					<table class="results-table">
						<thead>
							<tr><th>Date</th><th>Count</th><th>Sample IDs</th></tr>
						</thead>
						<tbody>
							<% dnaRecords.forEach(function(r){ %>
								<tr>
									<td><%= r.Date ? r.Date.toISOString().slice(0,10) : '' %></td>
									<td><%= r['Chum DNA Taken'] %></td>
									<td><%= r['Chum DNA IDs'] || '' %></td>
								</tr>
							<% }) %>
						</tbody>
					</table>
				<% } else { %>
					<p>No DNA records found for the selected range.</p>
				<% } %>

				<h3>Other Species Totals:</h3>
				<ul>
					<li><strong>Coho Fry:</strong> <%= totals.totalCohoFry || 0 %></li>
					<li><strong>Coho Parr:</strong> <%= totals.totalCohoParr || 0 %></li>
					<li><strong>Coho Smolt:</strong> <%= totals.totalCohoSmolt || 0 %></li>
					<li><strong>Steelhead:</strong> <%= totals.totalSteelhead || 0 %></li>
					<li><strong>Cutthroat:</strong> <%= totals.totalCutthroat || 0 %></li>
					<li><strong>Chinook:</strong> <%= totals.totalChinook || 0 %></li>
					<li><strong>Sculpin:</strong> <%= totals.totalSculpin || 0 %></li>
					<li><strong>Lamprey:</strong> <%= totals.totalLamprey || 0 %></li>
				</ul>

        <h3>Steelhead and Coho Mark and Recapture:</h3>
				<ul>
					<li><strong>Steelhead marked:</strong> <%= totals.totalSteelheadMarked || 0 %></li>
					<li><strong>Steelhead marked morts:</strong> <%= totals.totalSteelheadMarkedMort || 0 %></li>
					<li><strong>Steelhead recaptured:</strong> <%= totals.totalSteelheadRecap || 0 %></li>
					<li><strong>Steelhead recapture morts:</strong> <%= totals.totalSteelheadRecapMort || 0 %></li>
					<li><strong>Coho smolt marked:</strong> <%= totals.totalCohoSmoltMarked || 0 %></li>
					<li><strong>Coho smolt marked morts:</strong> <%= totals.totalCohoSmoltMarkedMort || 0 %></li>
					<li><strong>Coho smolt recaptured:</strong> <%= totals.totalCohoSmoltRecap || 0 %></li>
					<li><strong>Coho smolt recapture morts:</strong> <%= totals.totalCohoSmoltRecapMort || 0 %></li>
				</ul>

				<h3>Dates Trap Not Fishing:</h3>
				<%
          function fmtDate(d) {
            if (!d) return '?';
            return new Date(d).toISOString().slice(0, 10);
          }
        %>
				<% if (trapNotFishingPeriods && trapNotFishingPeriods.length) { %>
					<table class="results-table">
						<thead>
							<tr>
								<th>Date Cone Raised</th>
								<th>Time Raised</th>
								<th>Date Cone Lowered</th>
								<th>Time Lowered</th>
							</tr>
						</thead>
						<tbody>
							<% trapNotFishingPeriods.forEach(function(p) { %>
								<tr>
									<% if (p.historical) { %>
										<%
                      var s = fmtDate(p.start);
                      var e = fmtDate(p.end);
                    %>
										<td><%= s === e ? s : s + ' to ' + e %></td>
										<td>&mdash;</td>
										<td>&mdash;</td>
										<td>&mdash;</td>
									<% } else { %>
										<td><%= p.start ? fmtDate(p.start) : 'Before query range' %></td>
										<td><%= p.startTime || '&mdash;' %></td>
										<td><%= p.end ? fmtDate(p.end) : 'Still not fishing' %></td>
										<td><%= p.endTime || '&mdash;' %></td>
									<% } %>
								</tr>
							<% }) %>
						</tbody>
					</table>
				<% } else { %>
					<p>No trap 'not fishing' records in the selected range.</p>
				<% } %>
			</section>
		</main>

		<%- include("./partials/footer", { pageType: "Data Portal" }) %>
	</body>
</html>
